{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LatencyEvent",
  "type": "object",
  "required": [
    "trace_id",
    "channel",
    "message_type",
    "stage",
    "ts_unix_ms"
  ],
  "properties": {
    "trace_id": { "type": "string", "minLength": 8 },
    "channel": { "type": "string", "enum": ["whatsapp"] },
    "message_type": { "type": "string", "enum": ["text", "voice"] },
    "stage": {
      "type": "string",
      "enum": [
        "inbound_event_received",
        "processing_start",
        "audio_download_start",
        "audio_download_end",
        "transcribe_start",
        "transcribe_end",
        "json_load_start",
        "json_load_end",
        "search_start",
        "search_end",
        "tool_call_start",
        "tool_call_end",
        "llm_start",
        "llm_first_token",
        "llm_end",
        "response_sent"
      ]
    },
    "ts_unix_ms": { "type": "integer", "minimum": 0 },
    "mono_ns": { "type": ["integer", "null"], "minimum": 0 },
    "status": { "type": ["string", "null"], "enum": ["ok", "error", "timeout", "partial", null] },
    "error_code": { "type": ["string", "null"] },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "llm_provider": { "type": ["string", "null"] },
        "llm_model": { "type": ["string", "null"] },
        "payload_in_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "payload_out_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "audio_duration_ms": { "type": ["integer", "null"], "minimum": 0 },
        "tool_name": { "type": ["string", "null"] },
        "tool_call_index": { "type": ["integer", "null"], "minimum": 0 },
        "token_in": { "type": ["integer", "null"], "minimum": 0 },
        "token_out": { "type": ["integer", "null"], "minimum": 0 }
      }
    }
  },
  "additionalProperties": true
}

